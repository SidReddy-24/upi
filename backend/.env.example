# FraudShield Backend Environment Variables

# Database
DATABASE_URL=postgresql://fraudshield:your_password_here@localhost:5432/fraudshield

# Redis
REDIS_URL=redis://:your_redis_password_here@localhost:6379/0

# API Security
API_KEY=fs_demo_key_001
JWT_SECRET=your_jwt_secret_256_bit_key_here

# Server
HOST=0.0.0.0
PORT=8000
WORKERS=4

# Environment
ENV=development
DEBUG=true

# SMS Notifications (Twilio)
TWILIO_ENABLED=false
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_FROM_NUMBER=+1234567890

# Set TWILIO_ENABLED=true and add real credentials to enable SMS
# Get free trial account at: https://www.twilio.com/try-twilio
